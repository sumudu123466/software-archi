	<parameter name="pOrderId" class="java.lang.String"/>
	<query language="SQL"><![CDATA[SELECT 
    od.order_id, 
    i.name AS item_name, 
    od.qty, 
    od.price, 
    (od.qty * od.price) AS total
FROM order_details od
JOIN item i ON od.item_id = i.id
WHERE od.order_id = $P{pOrderId}]]></query>
