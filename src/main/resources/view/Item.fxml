<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1086.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.foodcity.controller.ItemController">
    <children>
        <ImageView fitHeight="768.0" fitWidth="1086.0" opacity="0.35" pickOnBounds="true" preserveRatio="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <image>
                <Image url="@../img/coffee.jpg" />
            </image>
        </ImageView>

        <AnchorPane style="-fx-background-color: rgba(0, 0, 0, 0.4);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

        <VBox spacing="20.0" style="-fx-padding: 40;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="Menu &amp; Inventory Management" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Separator prefWidth="200.0" style="-fx-opacity: 0.3;" />

                <GridPane hgap="20.0" style="-fx-background-color: rgba(255, 255, 255, 0.12); -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: rgba(255, 255, 255, 0.2); -fx-border-radius: 15;" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Item Code" textFill="WHITE" />
                                <TextField fx:id="txtCode" prefHeight="40.0" promptText="Ex: C001" style="-fx-background-radius: 8;" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1">
                            <children>
                                <Label text="Item Name" textFill="WHITE" />
                                <TextField fx:id="txtName" prefHeight="40.0" promptText="Ex: Espresso" style="-fx-background-radius: 8;" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.rowIndex="1">
                            <children>
                                <Label text="Unit Price (LKR)" textFill="WHITE" />
                                <TextField fx:id="txtPrice" prefHeight="40.0" promptText="0.00" style="-fx-background-radius: 8;" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <children>
                                <Label text="Stock Quantity" textFill="WHITE" />
                                <TextField fx:id="txtQty" prefHeight="40.0" promptText="0" style="-fx-background-radius: 8;" />
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button fx:id="btnDelete" onAction="#btnDeleteOnAction" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #451800; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Delete" />
                        <Button fx:id="btnUpdate" onAction="#btnUpdateOnAction" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #914400; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Update" />
                        <Button fx:id="btnSave" onAction="#btnSaveOnAction" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #a86616; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Save Item" />
                    </children>
                </HBox>

                <TableView fx:id="tblItem" onMouseClicked="#tblItemOnMouseClicked" prefHeight="350.0" style="-fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCode" prefWidth="120.0" text="Code" />
                        <TableColumn fx:id="colName" prefWidth="350.0" text="Item Name" />
                        <TableColumn fx:id="colPrice" prefWidth="150.0" text="Price (LKR)" />
                        <TableColumn fx:id="colQty" prefWidth="150.0" text="Qty On Hand" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>