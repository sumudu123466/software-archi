<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1086.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.foodcity.controller.PlaceOrderController">
    <children>
        <ImageView fitHeight="768.0" fitWidth="1086.0" opacity="0.4" pickOnBounds="true" preserveRatio="false">
            <image>
                <Image url="@../img/coffee.jpg" />
            </image>
        </ImageView>

        <AnchorPane style="-fx-background-color: rgba(0, 0, 0, 0.6);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

        <VBox spacing="20.0" style="-fx-padding: 30;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label text="PLACE ORDER FORM" textFill="WHITE">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>

                <GridPane hgap="20.0" vgap="15.0" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-padding: 20; -fx-background-radius: 15;">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Order ID:" textFill="WHITE" />
                        <TextField fx:id="txtOrderId" GridPane.rowIndex="1" />

                        <Label text="Customer ID:" textFill="WHITE" GridPane.columnIndex="1" />
                        <ComboBox fx:id="cmbCustomerId" onAction="#cmbCustomerOnAction" prefWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Item Code:" textFill="WHITE" GridPane.columnIndex="2" />
                        <ComboBox fx:id="cmbItemCode" onAction="#cmbItemOnAction" prefWidth="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    </children>
                </GridPane>

                <TableView fx:id="tblOrderCart" prefHeight="300.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colItemCode" prefWidth="120.0" text="Code" />
                        <TableColumn fx:id="colDescription" prefWidth="350.0" text="Description" />
                        <TableColumn fx:id="colQty" prefWidth="100.0" text="Qty" />
                        <TableColumn fx:id="colUnitPrice" prefWidth="150.0" text="Unit Price" />
                        <TableColumn fx:id="colTotal" prefWidth="150.0" text="Total" />
                        <TableColumn fx:id="colAction" prefWidth="120.0" text="Action" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="NET TOTAL :" textFill="#e74c3c">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <Label fx:id="lblNetTotal" text="0.00" textFill="#e74c3c">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnPlaceOrder" onAction="#btnPlaceOrderOnAction" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;" text="PLACE ORDER" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>