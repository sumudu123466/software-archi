<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="768.0" prefWidth="1086.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.foodcity.controller.CustomerController">
    <children>
        <ImageView fitHeight="768.0" fitWidth="1086.0" pickOnBounds="true" preserveRatio="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <image>
                <Image url="@../img/coffee.jpg" />
            </image>
        </ImageView>

        <AnchorPane style="-fx-background-color: rgba(45, 30, 23, 0.82);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />

        <VBox spacing="25.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0">
            <children>
                <Label text="Customer Management" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>

                <GridPane hgap="25.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-padding: 30; -fx-background-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.2); -fx-border-radius: 20;" vgap="20.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="300.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="300.0" />
                    </columnConstraints>
                    <children>
                        <Label text="NIC (ID):" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="txtCustId" prefHeight="40.0" promptText="Enter NIC" style="-fx-background-radius: 10; -fx-background-color: white;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Contact:" textFill="WHITE" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="txtCustContact" prefHeight="40.0" promptText="Enter Mobile Number" style="-fx-background-radius: 10; -fx-background-color: white;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                        <Label text="Name:" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="txtCustName" prefHeight="40.0" promptText="Enter Name" style="-fx-background-radius: 10; -fx-background-color: white;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Email:" textFill="WHITE" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextField fx:id="txtCustEmail" prefHeight="40.0" promptText="Enter Email" style="-fx-background-radius: 10; -fx-background-color: white;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                    </children>
                    <rowConstraints>
                        <RowConstraints />
                        <RowConstraints />
                    </rowConstraints>
                </GridPane>

                <HBox spacing="15.0">
                    <children>
                        <Button onAction="#saveCustomer" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #D2B48C; -fx-text-fill: #2D1E17; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="SAVE" />
                        <Button onAction="#updateCustomer" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="UPDATE" />
                        <Button onAction="#deleteCustomer" prefHeight="45.0" prefWidth="130.0" style="-fx-background-color: #FF5F57; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="DELETE" />
                    </children>
                </HBox>

                <TableView fx:id="tblCustomer" prefHeight="400.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="150.0" text="Customer NIC" />
                        <TableColumn fx:id="colName" prefWidth="250.0" text="Full Name" />
                        <TableColumn fx:id="colContact" prefWidth="150.0" text="Contact Number" />
                        <TableColumn fx:id="colEmail" prefWidth="250.0" text="Email Address" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>